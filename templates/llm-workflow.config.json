{
  "kitVersion": 1,
  "gate": ["pnpm typecheck", "pnpm lint", "pnpm run format:check", "pnpm test"],
  "verify": [
    {
      "name": "format",
      "globs": ["**/*.{ts,tsx,js,jsx,mjs,json,css}"],
      "commands": ["pnpm run format:check"]
    },
    {
      "name": "lint",
      "globs": ["**/*.{ts,tsx,js,jsx,mjs}"],
      "commands": ["pnpm lint"]
    },
    {
      "name": "typecheck",
      "globs": ["src/**", "tests/**", "tsconfig*.json", "package.json"],
      "commands": ["pnpm typecheck"]
    },
    {
      "name": "unit-tests",
      "globs": ["src/**", "tests/**"],
      "commands": ["pnpm test"]
    },
    {
      "name": "wiki-lint",
      "globs": ["docs/wiki/**"],
      "commands": ["node scripts/llm-workflow/wiki-lint.mjs"]
    }
  ],
  "lenses": {
    "security": ["src/server/**", "**/auth/**", "**/storage/**", "**/*secret*", "**/*token*"],
    "product": ["src/**/*.tsx", "src/**/*.css"],
    "complexity": ["package.json", "*.config.*", "scripts/**", "skills/**"]
  },
  "redFlags": {
    "consoleAllow": []
  },
  "wiki": {
    "ledgerDriftCommits": 15,
    "domainDriftCommits": 5
  }
}
